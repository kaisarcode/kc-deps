prefix=/usr/local/lib/kaisarcode/imagemagick/arm64-v8a
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include/ImageMagick-6
includearchdir=/usr/local/lib/kaisarcode/imagemagick/arm64-v8a/include/ImageMagick-6
libname=MagickCore-6.Q16
moduledir=${exec_prefix}/lib/ImageMagick-6.9.13/modules-Q16

Name: MagickCore
Description: MagickCore - C API for ImageMagick (ABI Q16)
URL: https://github.com/ImageMagick/ImageMagick6
Version: 6.9.13
Cflags: -I${includearchdir} -I${includedir} -DMAGICKCORE_HDRI_ENABLE=0 -DMAGICKCORE_QUANTUM_DEPTH=16
Libs: -L${libdir} -l${libname}
Libs.private: -L${libdir} -l${libname} -lm -ldl         -L/usr/local/lib/kaisarcode/imagemagick/arm64-v8a/lib -lpng16 -lm -lz -lm -L/usr/local/lib/kaisarcode/imagemagick/arm64-v8a/lib -L/usr/local/lib/kaisarcode/imagemagick/arm64-v8a/lib -lz                          -L/usr/local/lib/kaisarcode/imagemagick/arm64-v8a/lib -lz     -lm        -lm
