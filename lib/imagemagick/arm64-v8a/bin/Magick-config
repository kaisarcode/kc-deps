#!/bin/sh
#
# Configure options script for re-calling MagickCore compilation options
# required to use the MagickCore library.
#

prefix=/usr/local/lib/kaisarcode/imagemagick/arm64-v8a
exec_prefix=${prefix}

usage="\
Usage: Magick-config [--cflags] [--cppflags] [--exec-prefix] [--ldflags] [--libs] [--prefix] [--version]"

if test $# -eq 0; then
      echo "${usage}" 1>&2
      echo "Example: gcc \`Magick-config --cflags --cppflags\` -o core core.c \`Magick-config --ldflags --libs\`" 1>&2
      exit 1
fi

while test $# -gt 0; do
  case "$1" in
    -*=*) optarg=`echo "$1" | sed 's/[-_a-zA-Z0-9]*=//'` ;;
    *) optarg= ;;
  esac
  case $1 in
    --prefix=*)
      prefix=$optarg
      ;;
    --prefix)
      echo $prefix
      ;;
    --exec-prefix=*)
      exec_prefix=$optarg
      ;;
    --exec-prefix)
      echo $exec_prefix
      ;;
    --version)
      echo '6.9.13-16 Q16 '
      ;;
    --cc)
      echo '/usr/local/share/kaisarcode/toolchains/ndk/android-ndk-r27c/toolchains/llvm/prebuilt/linux-x86_64/bin/aarch64-linux-android24-clang'
      ;;
    --cflags)
      pkg-config --static --cflags MagickCore
      ;;
    --cxx)
      echo '/usr/local/share/kaisarcode/toolchains/ndk/android-ndk-r27c/toolchains/llvm/prebuilt/linux-x86_64/bin/aarch64-linux-android24-clang++'
      ;;
    --cxxflags)
      pkg-config --static --cflags MagickCore
      ;;
    --cppflags)
      pkg-config --static --cflags MagickCore
      ;;
    --ldflags)
      pkg-config --static --libs MagickCore
      ;;
    --libs)
      pkg-config --static --libs MagickCore
      ;;
    *)
      echo "${usage}" 1>&2
      exit 1
      ;;
  esac
  shift
done
